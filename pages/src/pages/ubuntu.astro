import { joinURL, withTrailingSlash } from "ufo";

import { Code } from "astro:components";

import Layout from "../layouts/Layout.astro";
import { PRODUCTION_BASE_URL } from "../lib/info.js";
import {
  ASSET_PATTERNS,
  findAsset,
  getLatestBgobsRelease,
} from "../lib/releases.js";

const { BASE_URL } = import.meta.env;
const release = await getLatestBgobsRelease();
const asset = findAsset(release, ASSET_PATTERNS.ubuntu);
const releaseDetails = withTrailingSlash(
  joinURL(BASE_URL, "versions", release.tag_name),
);
---

<Layout
  lang="en"
  title="Install BGOBS on Ubuntu"
  description="Check for and install an official BGOBS x86_64 Debian package for OBS Studio on Ubuntu."
  canonical={joinURL(PRODUCTION_BASE_URL, "ubuntu")}
>
  <main id="main-content" class="content-panel prose">
    <p class="eyebrow">Ubuntu x86_64</p>
    <h1>Install BGOBS on Ubuntu</h1>
    <p class="lede">
      Install only the Debian package attached to the official BGOBS GitHub
      release. Third-party packages carrying a similar filter name are not BGOBS
      builds.
    </p>

    {
      asset ? (
        <>
          <div class="button-row">
            <a
              class="button primary"
              href={asset.browser_download_url}
              download
            >
              Download {asset.name}
            </a>
            <a class="button" href={releaseDetails}>
              Verify this download
            </a>
          </div>

          <ol>
            <li>Close OBS Studio.</li>
            <li>
              Download <code>{asset.name}</code> from the button above.
            </li>
            <li>
              Open a terminal in the download directory and let APT install the
              local package and resolve its declared dependencies:
              <Code code={"sudo apt install ./" + asset.name} lang="bash" />
            </li>
            <li>Start OBS Studio again, then follow the usage guide.</li>
          </ol>
        </>
      ) : (
        <aside class="callout">
          <p>
            <strong>
              No Ubuntu package is attached to {release.tag_name}.
            </strong>{" "}
            Use the official Releases page to check future builds. BGOBS does
            not currently endorse an AUR, Flatpak, or other third-party package
            as a substitute.
          </p>
          <p>
            <a href={release.html_url}>Open the official GitHub release</a>
          </p>
        </aside>
      )
    }

    <h2>Next step</h2>
    <p>
      Open <a href={joinURL(BASE_URL, "usage/")}>Use BGOBS</a> to add the effect filter
      or an optional CaCam source.
    </p>

    <nav class="page-nav" aria-label="Page navigation">
      <a href={withTrailingSlash(BASE_URL)}>BGOBS home</a>
      <a href={release.html_url}>Official GitHub release</a>
    </nav>
  </main>
</Layout>
