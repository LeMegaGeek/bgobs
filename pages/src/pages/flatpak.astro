import { joinURL, withTrailingSlash } from "ufo";

import Layout from "../layouts/Layout.astro";
import { PRODUCTION_BASE_URL, RELEASES_URL } from "../lib/info.js";

const { BASE_URL } = import.meta.env;
---

<Layout
  lang="en"
  title="BGOBS and Flatpak"
  description="BGOBS does not currently publish or endorse a Flatpak package; use only assets from official BGOBS GitHub releases."
  canonical={joinURL(PRODUCTION_BASE_URL, "flatpak")}
>
  <main id="main-content" class="content-panel prose">
    <p class="eyebrow">Distribution status</p>
    <h1>No official BGOBS Flatpak package</h1>
    <p class="lede">
      BGOBS does not currently publish or endorse a Flatpak package. A package
      with a similar filter name may belong to another project and should not be
      treated as a BGOBS build.
    </p>
    <aside class="callout">
      <p>
        Use only BGOBS-branded assets attached to the official LeMegaGeek
        release. If no compatible package is listed, no supported Flatpak
        download is available for that release.
      </p>
    </aside>
    <nav class="page-nav" aria-label="Page navigation">
      <a href={RELEASES_URL}>Official GitHub Releases</a>
      <a href={withTrailingSlash(BASE_URL)}>BGOBS home</a>
    </nav>
  </main>
</Layout>
