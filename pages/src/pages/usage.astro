import { joinURL, withTrailingSlash } from "ufo";

import Layout from "../layouts/Layout.astro";
import { GITHUB_URL, PRODUCTION_BASE_URL } from "../lib/info.js";

const { BASE_URL } = import.meta.env;
---

<Layout
  lang="en"
  title="Use BGOBS in OBS Studio"
  description="Configure BGOBS background removal, blur and low-light enhancement filters, or add an optional CaCam USB or ADB source in OBS Studio."
  canonical={joinURL(PRODUCTION_BASE_URL, "usage")}
>
  <main id="main-content" class="content-panel prose">
    <p class="eyebrow">Usage guide</p>
    <h1>Use BGOBS in OBS Studio</h1>
    <p class="lede">
      BGOBS provides an effect filter for any compatible video source and a
      separate, optional CaCam source. Start with the filter unless you
      specifically need a phone feed.
    </p>

    <nav class="page-nav" aria-label="On this page">
      <a href="#filter">Background &amp; low-light filter</a>
      <a href="#cacam">Optional CaCam source</a>
      <a href="#troubleshooting">Troubleshooting</a>
    </nav>

    <section id="filter">
      <p class="eyebrow">Effect filter</p>
      <h2>Remove, replace, or blur a background</h2>
      <ol>
        <li>
          In OBS Studio, add or select the video source you want to process.
        </li>
        <li>
          Right-click the source, choose <strong>Filters</strong>, then add an
          effect filter named <strong>Make me look good</strong>.
        </li>
        <li>
          Choose a <strong>BGOBS style</strong> preset as a starting point. Use
          <strong>Custom</strong> only when you want to tune individual controls.
        </li>
        <li>
          Select a segmentation model and adjust the threshold, contour,
          feathering, and mask expansion while watching the preview.
        </li>
        <li>
          Set <strong>Blur background</strong> above zero for blur, or leave it at
          zero and choose a background color for removal/replacement.
        </li>
      </ol>

      <h3>Improve a dim portrait</h3>
      <p>
        Enable <strong>Enhance portrait</strong>, then raise
        <strong>Effect strength</strong> gradually. Enhancement requires extra processing,
        so compare OBS rendering time before and after enabling it.
      </p>

      <div class="callout info">
        <p>
          <strong>Practical starting point:</strong> use even front lighting, keep
          clear contrast between the subject and background, and start with a preset
          before opening advanced settings. The best model depends on the camera,
          scene, and available CPU or GPU.
        </p>
      </div>
    </section>

    <section id="cacam">
      <p class="eyebrow">Optional source</p>
      <h2>Bring in a CaCam phone feed</h2>
      <p>
        CaCam is a separate, private Android application. It is not required for
        BGOBS filters and its source code is not part of this repository.
      </p>
      <ol>
        <li>
          In OBS Studio, add a source named <strong>CaCam</strong>.
        </li>
        <li>
          Choose <strong>USB</strong> for a direct accessory connection or
          <strong>ADB</strong> for a local Android Debug Bridge connection.
        </li>
        <li>
          Select the requested quality and enable automatic connection only if
          you want the source to reconnect when the phone becomes available.
        </li>
        <li>
          Open CaCam on the phone and select its BGOBS connection mode. Accept
          Android's USB permission prompt when using direct USB.
        </li>
      </ol>

      <h3>USB mode</h3>
      <p>
        Connect the phone directly to the computer and avoid hubs while
        diagnosing a connection problem. Only one application can own the
        accessory connection at a time.
      </p>

      <h3>ADB mode</h3>
      <p>
        BGOBS needs a working <code>adb</code> executable. The Windows package may
        bundle it; on other systems, set <strong>ADB path</strong> if it is not available
        on <code>PATH</code>. Use <strong>ADB serial</strong> when more than one Android
        device is connected. Keep the default local and device ports unless they conflict
        with another service.
      </p>
    </section>

    <section id="troubleshooting">
      <p class="eyebrow">Support</p>
      <h2>When something does not appear</h2>
      <ul>
        <li>Restart OBS Studio after installing or replacing the plugin.</li>
        <li>
          Confirm that the package architecture matches OBS Studio and that the
          plugin came from the official BGOBS release.
        </li>
        <li>
          Check the OBS log for lines containing <code>BGOBS</code> or
          <code>CaCam</code>. Remove usernames, device serials, and private
          paths before sharing a log.
        </li>
        <li>
          Include the BGOBS version, OBS version, operating system,
          architecture, and connection mode in a bug report.
        </li>
      </ul>
      <div class="button-row">
        <a class="button" href={joinURL(BASE_URL, "support/")}
          >Support &amp; security guidance</a
        >
        <a class="button" href={GITHUB_URL + "/issues"}>Open GitHub Issues</a>
      </div>
    </section>

    <nav class="page-nav" aria-label="Page navigation">
      <a href={withTrailingSlash(BASE_URL)}>BGOBS home</a>
      <a href={joinURL(BASE_URL, "windows/")}>Installation guides</a>
    </nav>
  </main>
</Layout>
