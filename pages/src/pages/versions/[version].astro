import { joinURL, withTrailingSlash } from "ufo";
import prettyBytes from "pretty-bytes";
import type { GetStaticPathsResult } from "astro";
import { readFile } from "node:fs/promises";

import DefineFileVerifierDropArea from "../../components/DefineFileVerifierDropArea.astro";
import DefineLocalDate from "../../components/DefineLocalDate.astro";
import type { FileVerifierReleaseAsset } from "../../components/FileVerifierResultDialog.js";
import Layout from "../../layouts/Layout.astro";
import { GITHUB_URL, PRODUCTION_BASE_URL } from "../../lib/info.js";
import {
  ASSET_PATTERNS,
  findAsset,
  findRuntimeAssets,
  listBgobsReleases,
  type Release,
} from "../../lib/releases.js";

interface Props {
  release: Release;
  latestRelease: Release;
}

export async function getStaticPaths(): Promise<GetStaticPathsResult> {
  const releases = await listBgobsReleases();
  const latestRelease = releases[0];

  if (!latestRelease) {
    throw new Error("No published BGOBS release with official assets found.");
  }

  return releases.map((release) => ({
    params: { version: release.tag_name },
    props: { release, latestRelease },
  }));
}

function stripMarkdown(markdown: string): string {
  return markdown
    .replace(/^#+\s+/gm, "")
    .replace(/^[\s\-*+]+/gm, "")
    .replace(/\[([^\]]+)\]\([^)]+\)/g, "$1")
    .replace(/<[^>]+>/g, "")
    .replace(/`{1,3}/g, "")
    .replace(/[*_]{1,2}([^*_]+)[*_]{1,2}/g, "$1")
    .replace(/\s+/g, " ")
    .trim();
}

async function getReleaseNotes(tagName: string, fallback: string) {
  try {
    const path = new URL(
      `../../../../release-notes/${tagName}.md`,
      import.meta.url,
    );
    const localNotes = await readFile(path, "utf8");
    return localNotes.replace(/<!--[\s\S]*?-->/g, "").trim();
  } catch {
    return fallback;
  }
}

const { BASE_URL } = import.meta.env;
const { release, latestRelease } = Astro.props;
const runtimeAssets = findRuntimeAssets(release);
const checksumAsset = findAsset(release, ASSET_PATTERNS.checksums);
const releaseBody = await getReleaseNotes(
  release.tag_name,
  release.body?.trim() || "No release notes were provided.",
);
const verifiableAssets = release.assets.filter((asset) => asset.digest);
const releaseAssets = verifiableAssets.map(
  (asset) =>
    ({
      name: asset.name,
      size: asset.size,
      digest: asset.digest,
    }) satisfies FileVerifierReleaseAsset,
);

const baseDescription = `Download BGOBS ${release.tag_name} from the official release archive.`;
const cleanBody = stripMarkdown(releaseBody);
const description = cleanBody
  ? `${baseDescription} ${cleanBody}`.slice(0, 158)
  : baseDescription;
---

<Layout
  lang="en"
  title={`BGOBS ${release.tag_name} downloads and release notes`}
  description={description}
  canonical={joinURL(PRODUCTION_BASE_URL, "versions", release.tag_name)}
>
  <Fragment slot="head-bottom">
    <DefineLocalDate />
    <DefineFileVerifierDropArea />
  </Fragment>

  <main id="main-content" class="content-panel prose">
    <div class="version-title-row">
      <div>
        <p class="eyebrow">Official BGOBS release</p>
        <h1>{release.tag_name}</h1>
      </div>
      {
        release.id === latestRelease.id && (
          <span class="badge latest">Latest</span>
        )
      }
    </div>

    {
      release.prerelease && (
        <aside class="callout">
          <p>
            <strong>Pre-release:</strong> this build may be incomplete or
            unstable. Read its notes before installing it.
          </p>
        </aside>
      )
    }

    <section aria-labelledby="downloads-title">
      <h2 id="downloads-title">Runtime downloads</h2>
      {
        runtimeAssets.length > 0 ? (
          <ul class="download-links">
            {runtimeAssets.map((asset) => (
              <li>
                <a class="primary" href={asset.browser_download_url}>
                  {ASSET_PATTERNS.windows.test(asset.name)
                    ? "Windows x64"
                    : ASSET_PATTERNS.macos.test(asset.name)
                      ? "macOS universal"
                      : "Ubuntu x86_64"}
                </a>
              </li>
            ))}
          </ul>
        ) : (
          <aside class="callout">
            <p>
              This release has no recognized BGOBS runtime package. Use the
              GitHub release page to inspect its published files.
            </p>
          </aside>
        )
      }

      <div class="button-row">
        <a class="button" href={release.html_url}>View on GitHub</a>
        {
          checksumAsset && (
            <a class="button" href={checksumAsset.browser_download_url}>
              SHA-256 checksum list
            </a>
          )
        }
      </div>
    </section>

    {
      verifiableAssets.length > 0 ? (
        <section aria-labelledby="verify-title">
          <h2 id="verify-title">Verify a downloaded file locally</h2>
          <p>
            Choose or drop a release asset below. Your browser calculates its
            SHA-256 digest locally; the file is not uploaded. A matching digest
            confirms that the bytes match an asset recorded by this official
            GitHub release.
          </p>
          <file-verifier-drop-area id="verifier" />
        </section>
      ) : (
        <aside class="callout info">
          <p>
            GitHub does not expose a recorded digest for this release's assets,
            so browser verification is unavailable here. Use the published
            checksum list when present and obtain it from the same official
            release page.
          </p>
        </aside>
      )
    }

    <section class="release-notes" aria-labelledby="notes-title">
      <h2 id="notes-title">Release notes</h2>
      <pre>{releaseBody}</pre>
    </section>

    <section aria-labelledby="assets-title">
      <h2 id="assets-title">All published assets</h2>
      <ul class="asset-list">
        {
          release.assets.map((asset) => (
            <li>
              <a href={asset.browser_download_url}>{asset.name}</a>
              <small>{prettyBytes(asset.size, { binary: true })}</small>
            </li>
          ))
        }
      </ul>
    </section>

    <section aria-labelledby="details-title">
      <h2 id="details-title">Release details</h2>
      <dl>
        <dt>Published</dt>
        <dd>
          {
            release.published_at ? (
              <local-date data-date={release.published_at}>
                <time datetime={release.published_at}>
                  {release.published_at}
                </time>
              </local-date>
            ) : (
              "Unknown"
            )
          }
        </dd>
        <dt>License</dt>
        <dd>GPL-3.0-or-later</dd>
        <dt>Repository</dt>
        <dd><a href={GITHUB_URL}>{GITHUB_URL}</a></dd>
      </dl>
    </section>

    <nav class="page-nav" aria-label="Page navigation">
      <a href={withTrailingSlash(BASE_URL)}>BGOBS home</a>
      <a href={withTrailingSlash(joinURL(BASE_URL, "versions"))}
        >All BGOBS versions</a
      >
      <a href={release.html_url}>GitHub release</a>
    </nav>

    <file-verifier-result-dialog
      id="verifier-dialog"
      data-release-assets={JSON.stringify(releaseAssets)}
    ></file-verifier-result-dialog>
  </main>

  <Fragment slot="body-bottom">
    <script>
      import { FileVerifierResultDialog } from "../../components/FileVerifierResultDialog";

      if (!customElements.get("file-verifier-result-dialog")) {
        customElements.define(
          "file-verifier-result-dialog",
          FileVerifierResultDialog,
        );
      }

      function uint8ArrayToHex(bytes: Uint8Array): string {
        return Array.from(bytes)
          .map((byte) => byte.toString(16).padStart(2, "0"))
          .join("");
      }

      const verifierDropArea = document.getElementById("verifier");
      const verifierResultDialog = document.getElementById(
        "verifier-dialog",
      ) as FileVerifierResultDialog | null;

      if (verifierDropArea && verifierResultDialog) {
        verifierDropArea.addEventListener(
          "file-verifier-file-dropped",
          (event) => {
            const { name, size, sha256Buffer } = event.detail;
            verifierResultDialog.addResult({
              name,
              size,
              sha256: uint8ArrayToHex(new Uint8Array(sha256Buffer)),
            });
            verifierResultDialog.showModal();
          },
        );

        verifierDropArea.addEventListener("file-verifier-error", (event) => {
          const { name, size, error } = event.detail;
          verifierResultDialog.addResult({ name, size, error });
          verifierResultDialog.showModal();
        });
      }
    </script>
  </Fragment>
</Layout>

<style>
  .version-title-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .version-title-row h1 {
    margin-bottom: 0;
  }

  dt {
    margin-top: 0.8rem;
    font-weight: 750;
  }

  dd {
    margin-left: 0;
    overflow-wrap: anywhere;
  }
</style>
