import { joinURL, withTrailingSlash } from "ufo";

import DefineLocalDate from "../../components/DefineLocalDate.astro";
import Layout from "../../layouts/Layout.astro";
import { GITHUB_URL, PRODUCTION_BASE_URL } from "../../lib/info.js";
import { listBgobsReleases } from "../../lib/releases.js";

const { BASE_URL } = import.meta.env;
const releases = await listBgobsReleases();
const [latestRelease, ...pastReleases] = releases;

if (!latestRelease) {
  throw new Error("No published BGOBS release with official assets found.");
}
---

<Layout
  lang="en"
  title="BGOBS release archive"
  description="Browse official BGOBS releases, platform downloads, release notes, checksums, and local file-verification tools."
  canonical={joinURL(PRODUCTION_BASE_URL, "versions")}
>
  <Fragment slot="head-bottom">
    <DefineLocalDate />
  </Fragment>

  <main id="main-content" class="content-panel prose">
    <p class="eyebrow">Official release archive</p>
    <h1>BGOBS versions</h1>
    <p class="lede">
      This archive includes only releases carrying BGOBS-branded assets from the
      official LeMegaGeek repository.
    </p>

    <section class="card accent-card" aria-labelledby="latest-title">
      <span class="badge latest">Latest</span>
      <h2 id="latest-title">{latestRelease.tag_name}</h2>
      {
        latestRelease.published_at && (
          <p>
            Published{" "}
            <local-date data-date={latestRelease.published_at}>
              <time datetime={latestRelease.published_at}>
                {latestRelease.published_at}
              </time>
            </local-date>
          </p>
        )
      }
      <a
        class="button primary"
        href={withTrailingSlash(
          joinURL(BASE_URL, "versions", latestRelease.tag_name),
        )}
      >
        Downloads and release notes
      </a>
    </section>

    <h2>Earlier BGOBS releases</h2>
    {
      pastReleases.length > 0 ? (
        <ol class="release-list" reversed>
          {pastReleases.map((release) => (
            <li>
              <a
                href={withTrailingSlash(
                  joinURL(BASE_URL, "versions", release.tag_name),
                )}
              >
                <strong>{release.tag_name}</strong>
              </a>
              {release.published_at && (
                <local-date data-date={release.published_at}>
                  <time datetime={release.published_at}>
                    {release.published_at}
                  </time>
                </local-date>
              )}
            </li>
          ))}
        </ol>
      ) : (
        <p>No earlier BGOBS-branded release is available.</p>
      )
    }

    <nav class="page-nav" aria-label="Page navigation">
      <a href={withTrailingSlash(BASE_URL)}>BGOBS home</a>
      <a href={GITHUB_URL + "/releases"}>GitHub Releases</a>
    </nav>
  </main>
</Layout>

<style>
  .release-list {
    padding: 0;
    list-style: none;
  }

  .release-list li {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    padding: 0.8rem 0;
    border-bottom: 1px solid var(--line);
    gap: 1rem;
  }

  .release-list local-date {
    color: var(--muted);
  }
</style>
