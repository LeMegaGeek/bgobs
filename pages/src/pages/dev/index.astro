import { joinURL, withTrailingSlash } from "ufo";

import Layout from "../../layouts/Layout.astro";
import { GITHUB_URL, PRODUCTION_BASE_URL } from "../../lib/info.js";

const { BASE_URL } = import.meta.env;
---

<Layout
  lang="en"
  title="Develop BGOBS"
  description="Contribute to the public BGOBS source repository and run its current documented validation checks."
  canonical={joinURL(PRODUCTION_BASE_URL, "dev")}
>
  <main id="main-content" class="content-panel prose">
    <p class="eyebrow">Open development</p>
    <h1>Develop BGOBS</h1>
    <p class="lede">
      The canonical build and contribution instructions live with the source so
      they stay aligned with the current toolchain.
    </p>

    <div class="grid two-up">
      <section class="card">
        <h2>Build and test</h2>
        <p>
          Start with the repository's development guide for current CMake, Rust,
          native-test, and website validation commands.
        </p>
        <a class="button" href={GITHUB_URL + "/blob/main/docs/DEVELOPMENT.md"}
          >Development guide</a
        >
      </section>
      <section class="card">
        <h2>Contribute</h2>
        <p>
          Read the contribution, licensing, privacy, and AI-assistance rules
          before opening a pull request.
        </p>
        <a class="button" href={GITHUB_URL + "/blob/main/CONTRIBUTING.md"}
          >Contribution guide</a
        >
      </section>
    </div>

    <aside class="callout info">
      <p>
        BGOBS is the public plugin repository. Do not add private CaCam source,
        credentials, identifiable recordings, device serials, or unsanitized OBS
        logs to a commit or issue.
      </p>
    </aside>

    <nav class="page-nav" aria-label="Page navigation">
      <a href={withTrailingSlash(BASE_URL)}>BGOBS home</a>
      <a href={GITHUB_URL}>Browse source</a>
    </nav>
  </main>
</Layout>
