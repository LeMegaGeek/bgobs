import { joinURL } from "ufo";

import DefineLocalDate from "../components/DefineLocalDate.astro";
import Layout from "../layouts/Layout.astro";
import { GITHUB_URL, LICENSE_URL, PRODUCTION_BASE_URL } from "../lib/info.js";
import {
  ASSET_PATTERNS,
  findAsset,
  getLatestBgobsRelease,
} from "../lib/releases.js";

const { BASE_URL } = import.meta.env;
const release = await getLatestBgobsRelease();
const windowsAsset = findAsset(release, ASSET_PATTERNS.windows);
const macosAsset = findAsset(release, ASSET_PATTERNS.macos);
const ubuntuAsset = findAsset(release, ASSET_PATTERNS.ubuntu);
---

<Layout
  lang="en"
  title="BGOBS"
  description="BGOBS (Beau Gosse) is an independent, open-source OBS Studio plugin for background removal, background blur, low-light enhancement, and optional CaCam USB or ADB sources."
  canonical={PRODUCTION_BASE_URL}
>
  <Fragment slot="head-bottom">
    <DefineLocalDate />
  </Fragment>

  <main id="main-content">
    <section class="hero" aria-labelledby="hero-title">
      <div class="hero-copy">
        <p class="eyebrow">Independent · Open source · GPL-3.0-or-later</p>
        <h1 id="hero-title">
          Look sharp on camera.<br /><span>Stay in control.</span>
        </h1>
        <p class="lede">
          BGOBS — “Beau Gosse” — is a third-party plugin for OBS Studio. Remove
          or blur a background, improve a dim portrait, and optionally bring a
          CaCam phone feed into OBS over USB or ADB.
        </p>
        <div class="button-row">
          <a class="button primary" href={release.html_url}
            >Get {release.tag_name}</a
          >
          <a class="button" href={joinURL(BASE_URL, "usage/")}
            >Read the usage guide</a
          >
          <a class="button" href={GITHUB_URL}>View source on GitHub</a>
        </div>
      </div>

      <aside class="hero-card" aria-label="Latest BGOBS release">
        <span class="badge latest">Latest release</span>
        <h2>{release.tag_name}</h2>
        {
          release.published_at && (
            <p>
              Published{" "}
              <local-date data-date={release.published_at}>
                <time datetime={release.published_at}>
                  {release.published_at}
                </time>
              </local-date>
            </p>
          )
        }
        <ul>
          <li class:list={{ available: windowsAsset }}>Windows x64</li>
          <li class:list={{ available: macosAsset }}>macOS universal</li>
          <li class:list={{ available: ubuntuAsset }}>Ubuntu x86_64</li>
        </ul>
        <small>Green dots indicate an installer in this exact release.</small>
      </aside>
    </section>

    <section class="section-block" aria-labelledby="features-title">
      <p class="eyebrow">One plugin, focused tools</p>
      <h2 id="features-title">Made for a cleaner camera scene</h2>
      <div class="grid">
        <article class="card">
          <h3>Background control</h3>
          <p>
            Remove a background, replace it with a color, or keep the scene and
            apply a depth-aware blur.
          </p>
        </article>
        <article class="card">
          <h3>Low-light enhancement</h3>
          <p>
            Improve a dim portrait from the same BGOBS effect filter, with
            adjustable strength and processing options.
          </p>
        </article>
        <article class="card">
          <h3>Optional phone sources</h3>
          <p>
            Add a separate CaCam source through direct USB or a local ADB
            connection when the Android app is available to you.
          </p>
        </article>
      </div>
    </section>

    <section class="section-block split" aria-labelledby="downloads-title">
      <div>
        <p class="eyebrow">Official downloads</p>
        <h2 id="downloads-title">Install only what this release publishes</h2>
        <p>
          Platform pages inspect the official GitHub release. When an installer
          is missing, the page says so and links back to Releases instead of
          sending you to an unrelated package.
        </p>
      </div>
      <ul class="download-links">
        <li><a href={joinURL(BASE_URL, "windows/")}>Windows</a></li>
        <li><a href={joinURL(BASE_URL, "macos/")}>macOS</a></li>
        <li><a href={joinURL(BASE_URL, "ubuntu/")}>Ubuntu</a></li>
        <li><a href={joinURL(BASE_URL, "versions/")}>Release archive</a></li>
      </ul>
    </section>

    <section class="section-block" aria-labelledby="open-title">
      <p class="eyebrow">Transparent by design</p>
      <h2 id="open-title">BGOBS is public. CaCam is separate.</h2>
      <div class="grid two-up">
        <article class="card accent-card">
          <h3>BGOBS</h3>
          <p>
            The plugin source, issue tracker, build history, and license are
            public. BGOBS is distributed under{" "}
            <a href={LICENSE_URL}>GPL-3.0-or-later</a>.
          </p>
        </article>
        <article class="card">
          <h3>CaCam</h3>
          <p>
            CaCam is a separate, privately developed Android application. It is
            optional: BGOBS background and low-light filters work without it.
          </p>
        </article>
      </div>
      <div class="callout info">
        <p>
          <strong>Independent project:</strong> BGOBS is not an official OBS Studio
          component and is not affiliated with or endorsed by the OBS Project.
        </p>
      </div>
    </section>
  </main>
</Layout>
