import { joinURL, withTrailingSlash } from "ufo";

import Layout from "../layouts/Layout.astro";
import { PRODUCTION_BASE_URL } from "../lib/info.js";
import {
  ASSET_PATTERNS,
  findAsset,
  getLatestBgobsRelease,
} from "../lib/releases.js";

const { BASE_URL } = import.meta.env;
const release = await getLatestBgobsRelease();
const asset = findAsset(release, ASSET_PATTERNS.windows);
const releaseDetails = withTrailingSlash(
  joinURL(BASE_URL, "versions", release.tag_name),
);
---

<Layout
  lang="en"
  title="Install BGOBS on Windows"
  description="Download and install the official BGOBS plugin package for 64-bit OBS Studio on Windows."
  canonical={joinURL(PRODUCTION_BASE_URL, "windows")}
>
  <main id="main-content" class="content-panel prose">
    <p class="eyebrow">Windows x64</p>
    <h1>Install BGOBS on Windows</h1>
    <p class="lede">
      BGOBS supports 64-bit OBS Studio on Windows 10 and Windows 11. Use the ZIP
      attached to the official BGOBS release; it keeps the plugin binary,
      models, USB library, and optional ADB tools together.
    </p>

    {
      asset ? (
        <>
          <div class="button-row">
            <a
              class="button primary"
              href={asset.browser_download_url}
              download
            >
              Download {asset.name}
            </a>
            <a class="button" href={releaseDetails}>
              Verify this download
            </a>
          </div>

          <h2>Standard OBS Studio installation</h2>
          <ol>
            <li>Close OBS Studio.</li>
            <li>
              Extract <code>{asset.name}</code> to a temporary folder.
            </li>
            <li>
              Copy the extracted <code>bgobs</code> folder into{" "}
              <code>C:\ProgramData\obs-studio\plugins\</code>.
            </li>
            <li>
              Confirm that{" "}
              <code>
                C:\ProgramData\obs-studio\plugins\bgobs\bin\64bit\bgobs.dll
              </code>{" "}
              exists. Keep the packaged support files beside the plugin; do not
              move individual DLLs into another plugin's folder.
            </li>
            <li>Start OBS Studio again, then follow the usage guide.</li>
          </ol>

          <aside class="callout">
            <p>
              <strong>Do not copy this package into Program Files.</strong> The
              ZIP is laid out for OBS Studio's system plugin directory under{" "}
              <code>ProgramData</code>. Portable OBS installations should follow
              the text instructions bundled in the ZIP because their root path
              varies.
            </p>
          </aside>
        </>
      ) : (
        <aside class="callout">
          <p>
            <strong>
              No Windows runtime ZIP is attached to {release.tag_name}.
            </strong>{" "}
            Check the official release page instead of downloading a package
            published under another plugin name.
          </p>
          <p>
            <a href={release.html_url}>Open {release.tag_name} on GitHub</a>
          </p>
        </aside>
      )
    }

    <h2>Next step</h2>
    <p>
      Open <a href={joinURL(BASE_URL, "usage/")}>Use BGOBS</a> to add the effect filter
      or an optional CaCam source.
    </p>

    <nav class="page-nav" aria-label="Page navigation">
      <a href={withTrailingSlash(BASE_URL)}>BGOBS home</a>
      <a href={release.html_url}>Official GitHub release</a>
    </nav>
  </main>
</Layout>
