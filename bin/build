# SPDX-License-Identifier: Apache-2.0

cd "$(dirname "${BASH_SOURCE[0]}")/.."

debian_forky() {
  set -euo pipefail
  shopt -s nullglob

  if [ -z "${VCPKG_ROOT:-}" ]; then
    export VCPKG_ROOT="$PWD/vcpkg"
  fi

  cmake -G Ninja \
    -DCMAKE_INSTALL_LIBDIR=lib/CMAKE_SYSTEM_PROCESSOR-linux-gnu \
    -DCMAKE_INSTALL_PREFIX=/usr \
    -S . -B build_debian_forky

  cmake --build build_debian_forky

  (cd build_debian_forky && cpack -G DEB)

  printf 'Run the following command to install the plugin:\n'
  printf '  sudo dpkg -i %s\n' "$(pwd)/release/obs-backgroundremoval-*-linux-gnu.deb"
}

if [ -f /etc/os-release ]; then
  # shellcheck disable=SC1091
  . /etc/os-release

  case "$NAME" in
  'Debian GNU/Linux')
    case "$VERSION_CODENAME" in
    forky)
      debian_forky
      exit 0
      ;;
    *)
      printf 'ERROR: Debian %s is not supported.\n' "$VERSION_CODENAME" >&2
      exit 1
      ;;
    esac
    ;;
  esac
fi

printf 'ERROR: Your platform is not supported. Exiting...' >&2
exit 1
