#!/usr/bin/env bash

# SPDX-FileCopyrightText: 2026 Kaito Udagawa <umireon@kaito.tokyo>
#
# SPDX-License-Identifier: Apache-2.0

set -euo pipefail
shopt -s nullglob

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
: "${PLUGIN_BUILD_DIR:=$ROOT_DIR}"

debian_forky() {
  cmake -G Ninja -S "$ROOT_DIR" -B "$PLUGIN_BUILD_DIR/build"

  cmake --build "$PLUGIN_BUILD_DIR/build"

  (cd "$PLUGIN_BUILD_DIR/build" && cpack -G DEB)

  printf 'Run the following command to install the plugin:\n'
  printf '  sudo dpkg -i %s\n' "$ROOT_DIR/release/obs-backgroundremoval_*.deb"
}

ubuntu_resolute() {
  cmake -G Ninja -S "$ROOT_DIR" -B "$PLUGIN_BUILD_DIR/build"

  cmake --build "$PLUGIN_BUILD_DIR/build"

  (cd "$PLUGIN_BUILD_DIR/build" && cpack -G DEB)

  printf 'Run the following command to install the plugin:\n'
  printf '  sudo dpkg -i %s\n' "$ROOT_DIR/release/obs-backgroundremoval_*.deb"
}

if [ -f /etc/os-release ]; then
  # shellcheck disable=SC1091
  . /etc/os-release

  case "$NAME" in
  'Debian GNU/Linux')
    case "$VERSION_CODENAME" in
    forky)
      debian_forky
      exit 0
      ;;
    *)
      printf 'ERROR: Debian %s is not supported.\n' "$VERSION_CODENAME" >&2
      exit 1
      ;;
    esac
    ;;
  Ubuntu)
    case "$VERSION_CODENAME" in
    resolute)
      ubuntu_resolute
      exit 0
      ;;
    *)
      printf 'ERROR: Ubuntu %s is not supported.\n' "$VERSION_CODENAME" >&2
      exit 1
      ;;
    esac
    ;;
  esac
fi

printf 'ERROR: Your platform is not supported. Exiting...' >&2
exit 1
