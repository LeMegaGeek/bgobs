#!/usr/bin/env bash

# SPDX-FileCopyrightText: 2026 Kaito Udagawa <umireon@kaito.tokyo>
#
# SPDX-License-Identifier: Apache-2.0

set -euo pipefail
shopt -s nullglob

debian_forky() {
  apt-get update
  apt-get install -y --no-install-recommends \
    build-essential \
    ca-certificates \
    cargo \
    cmake \
    curl \
    file \
    git \
    libcurl4-openssl-dev \
    libobs-dev \
    libonnxruntime-dev \
    libopencv-dev \
    libopencv-imgcodecs-dev \
    libusb-1.0-0 \
    ninja-build \
    python3 \
    rustc \
    tar \
    unzip \
    zip
}

ubuntu_resolute() {
  apt-get update
  apt-get install -y --no-install-recommends \
    build-essential \
    ca-certificates \
    cargo \
    cmake \
    curl \
    file \
    git \
    libcurl4-openssl-dev \
    libobs-dev \
    libonnxruntime-dev \
    libopencv-dev \
    libopencv-imgcodecs-dev \
    libusb-1.0-0 \
    ninja-build \
    python3 \
    rustc \
    tar \
    unzip \
    zip
}

macos() {
  brew install ccache python@3.13 rust xcbeautify
}

case "$(uname -s)" in
Darwin)
  macos
  exit 0
  ;;
*)
  if [ -f /etc/os-release ]; then
    # shellcheck disable=SC1091
    . /etc/os-release

    linux_family=""
    case " ${ID:-} ${ID_LIKE:-} " in
    *" ubuntu "*) linux_family=ubuntu ;;
    *" debian "*) linux_family=debian ;;
    esac

    case "$linux_family" in
    debian)
      case "${VERSION_CODENAME:-}" in
      trixie | forky)
        debian_forky
        exit 0
        ;;
      *)
        printf 'ERROR: Debian %s is not supported.\n' "$VERSION_CODENAME" >&2
        exit 1
        ;;
      esac
      ;;
    ubuntu)
      case "${UBUNTU_CODENAME:-${VERSION_CODENAME:-}}" in
      noble | resolute)
        ubuntu_resolute
        exit 0
        ;;
      *)
        printf 'ERROR: Ubuntu %s is not supported.\n' "$VERSION_CODENAME" >&2
        exit 1
        ;;
      esac
      ;;
    esac
  fi
  ;;
esac

printf 'ERROR: Your platform is not supported. Exiting...' >&2
exit 1
