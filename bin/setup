#!/usr/bin/env bash

# SPDX-FileCopyrightText: 2026 Kaito Udagawa <umireon@kaito.tokyo>
#
# SPDX-License-Identifier: Apache-2.0

set -euo pipefail
shopt -s nullglob

: "${ORT_VERSION:=v1.23.2}"

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
: "${PLUGIN_BUILD_DIR:="$ROOT_DIR"}"

clone_onnxruntime() {
  if [ -d "$PLUGIN_BUILD_DIR/onnxruntime" ]; then
    git -C "$PLUGIN_BUILD_DIR/onnxruntime" reset --hard
  else
    git clone --depth 1 --branch "$ORT_VERSION" https://github.com/microsoft/onnxruntime.git "$PLUGIN_BUILD_DIR/onnxruntime"
  fi

  patches=("$ROOT_DIR"/scripts/ort_patches/"$ORT_VERSION"/*.patch)
  if [[ "${#patches[@]}" -gt 0 ]]; then
    git -C "$PLUGIN_BUILD_DIR/onnxruntime" apply -v "${patches[@]}"
  fi
}

debian_forky() {
  clone_onnxruntime
}

ubuntu_resolute() {
  clone_onnxruntime
}

if [ -f /etc/os-release ]; then
  # shellcheck disable=SC1091
  . /etc/os-release

  case "$NAME" in
  'Debian GNU/Linux')
    case "$VERSION_CODENAME" in
    forky)
      debian_forky
      exit 0
      ;;
    *)
      printf 'ERROR: Debian %s is not supported.\n' "$VERSION_CODENAME" >&2
      exit 1
      ;;
    esac
    ;;
  Ubuntu)
    case "$VERSION_CODENAME" in
    resolute)
      ubuntu_resolute
      exit 0
      ;;
    *)
      printf 'ERROR: Ubuntu %s is not supported.\n' "$VERSION_CODENAME" >&2
      exit 1
      ;;
    esac
    ;;
  esac
fi

printf 'ERROR: Your platform is not supported. Exiting...' >&2
exit 1
